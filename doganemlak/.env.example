# Canlı site adresi (canonical, sitemap, şema URL'leri)
VITE_SITE_URL=https://www.doganemlak.com

# API kökü (ör. http://localhost:5000/api) — görseller için OG mutlak URL üretiminde kullanılır
VITE_API_URL=http://localhost:5000/api

# Varsayılan paylaşım görseli (tam https URL, örn. 1200x630 logo/kapak)
VITE_OG_IMAGE_URL=

# İsteğe bağlı: RealEstateAgent şemasında telefon
VITE_ORG_PHONE=
