# MongoDB
MONGODB_URI=mongodb://localhost:27017/doganemlak

# Sunucu (opsiyonel)
PORT=5000

# API İçin Temel URL (Sitemap oluşturma veya server URL ihtiyaçları için)
API_URL=http://localhost:5000/api/listings?limit=500

# Frontend URL (Şifre sıfırlama yönlendirmesi vs. için)
FRONTEND_URL=http://localhost:5173

# JWT (Auth için zorunlu; production'da mutlaka güçlü bir değer kullanın)
JWT_SECRET=your-secret-key

# Mail Ayarları (Şifre sıfırlama vb. için)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
